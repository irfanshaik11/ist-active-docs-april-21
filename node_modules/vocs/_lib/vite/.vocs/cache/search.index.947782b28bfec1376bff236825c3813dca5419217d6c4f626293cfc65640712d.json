"{\"value\":{\"mdx\":\"---\\nlayout: landing\\n---\\n\\n<div style={{ background: 'linear-gradient(135deg, #0a0a0f 0%, #111827 50%, #0a0a0f 100%)', color: '#e5e7eb', minHeight: '100vh' }}>\\n\\n{/* Hero Section */}\\n<div style={{ maxWidth: '1100px', margin: '0 auto', padding: '80px 24px 60px', textAlign: 'center' }}>\\n  <img src=\\\"/hero-banner.png\\\" alt=\\\"Interstate\\\" style={{ maxWidth: '100%', width: '600px', marginBottom: '24px' }} />\\n  <p style={{ fontSize: 'clamp(18px, 2.5vw, 22px)', lineHeight: 1.7, color: '#9ca3af', maxWidth: '720px', margin: '0 auto 40px' }}>\\n    The fastest and most feature-rich hybrid web trading experience, designed to elevate your crypto journey with advanced analytics and high-speed execution.\\n  </p>\\n  <div style={{ display: 'flex', gap: '16px', justifyContent: 'center', flexWrap: 'wrap' }}>\\n    <a href=\\\"#\\\" style={{ display: 'inline-flex', alignItems: 'center', padding: '14px 32px', borderRadius: '12px', background: 'linear-gradient(135deg, #6366f1, #4f46e5)', color: '#fff', fontSize: '16px', fontWeight: 600, textDecoration: 'none', transition: 'transform 0.2s' }}>\\n      Launch App\\n    </a>\\n    <a href=\\\"/terms-of-service\\\" style={{ display: 'inline-flex', alignItems: 'center', padding: '14px 32px', borderRadius: '12px', border: '1px solid rgba(99, 102, 241, 0.3)', background: 'rgba(99, 102, 241, 0.05)', color: '#c7d2fe', fontSize: '16px', fontWeight: 600, textDecoration: 'none' }}>\\n      Read Docs\\n    </a>\\n  </div>\\n</div>\\n\\n{/* One Click Trading */}\\n<div style={{ maxWidth: '1100px', margin: '0 auto', padding: '40px 24px 80px', textAlign: 'center' }}>\\n  <p style={{ fontSize: '18px', lineHeight: 1.8, color: '#9ca3af', maxWidth: '800px', margin: '0 auto' }}>\\n    Buy and sell in one click, giving you the competitive edge needed in fast-paced markets. With wallet tracking and twitter monitoring, Interstate is packed with powerful features tailored for both beginners and pro traders.\\n  </p>\\n</div>\\n\\n{/* Features Grid */}\\n<div style={{ maxWidth: '1100px', margin: '0 auto', padding: '0 24px 80px' }}>\\n  <div style={{ textAlign: 'center', marginBottom: '48px' }}>\\n    <h2 style={{ fontSize: '36px', fontWeight: 700, color: '#f9fafb', margin: '0 0 16px' }}>\\n      Powerful Features\\n    </h2>\\n    <p style={{ fontSize: '18px', color: '#6b7280', maxWidth: '600px', margin: '0 auto' }}>\\n      Everything you need to trade with speed and confidence\\n    </p>\\n  </div>\\n  <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(240px, 1fr))', gap: '20px' }}>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#9889;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Buy on Migration</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Automatically buy tokens the moment they migrate, securing early entries on new launches.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#128200;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Sell on Migration</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Lock in profits automatically when tokens migrate, ensuring you never miss a profitable exit.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#127919;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Spot Buys</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Execute instant spot purchases with optimized routing for the best available price.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#128176;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Quick Sell</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>One-click selling lets you exit positions instantly when speed matters most.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#128038;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Twitter Monitor</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Track influential accounts in real time and act on market-moving tweets before the crowd.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#128065;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Wallet Tracking</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Follow top-performing wallets and mirror successful traders' moves in real time.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#128202;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Limit Orders</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Set precise entry and exit points with advanced limit orders that execute automatically.</p>\\n    </div>\\n\\n    <div style={{ padding: '28px', borderRadius: '16px', border: '1px solid rgba(99, 102, 241, 0.15)', background: 'rgba(17, 24, 39, 0.6)', backdropFilter: 'blur(8px)' }}>\\n      <div style={{ fontSize: '28px', marginBottom: '12px' }}>&#128295;</div>\\n      <h3 style={{ fontSize: '18px', fontWeight: 600, color: '#f9fafb', margin: '0 0 8px' }}>Migration Tools</h3>\\n      <p style={{ fontSize: '14px', color: '#6b7280', margin: 0, lineHeight: 1.6 }}>Complete suite of migration tools to help you capitalize on every token launch event.</p>\\n    </div>\\n\\n  </div>\\n</div>\\n\\n{/* Speed Section */}\\n<div style={{ maxWidth: '1100px', margin: '0 auto', padding: '0 24px 80px' }}>\\n  <div style={{ padding: '48px', borderRadius: '20px', border: '1px solid rgba(99, 102, 241, 0.2)', background: 'linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(17, 24, 39, 0.6) 100%)', textAlign: 'center' }}>\\n    <h2 style={{ fontSize: '32px', fontWeight: 700, color: '#f9fafb', margin: '0 0 16px' }}>\\n      Every Second Counts\\n    </h2>\\n    <p style={{ fontSize: '18px', lineHeight: 1.8, color: '#9ca3af', maxWidth: '700px', margin: '0 auto' }}>\\n      In the market of token launches and high-frequency trading, every second counts, and Interstate is your ultimate tool for securing massive gains. Whether you're here to capitalize on the latest opportunities or execute trades with confidence, Interstate provides you with precision, speed, and reliability.\\n    </p>\\n  </div>\\n</div>\\n\\n{/* Mission Section */}\\n<div style={{ maxWidth: '1100px', margin: '0 auto', padding: '0 24px 80px', textAlign: 'center' }}>\\n  <h2 style={{ fontSize: '36px', fontWeight: 700, color: '#f9fafb', margin: '0 0 16px' }}>\\n    Our Mission\\n  </h2>\\n  <p style={{ fontSize: '18px', lineHeight: 1.8, color: '#9ca3af', maxWidth: '800px', margin: '0 auto 40px' }}>\\n    At Interstate, our mission is to build a comprehensive, all-in-one trading platform that not only delivers unmatched performance but also rewards our users for being part of our growth. We are committed to being the fastest, most efficient, and most community-driven trading experience in the market—implementing the features you want most while ensuring a seamless and rewarding journey.\\n  </p>\\n  <p style={{ fontSize: '16px', fontWeight: 600, color: '#818cf8' }}>\\n    — The Interstate Team\\n  </p>\\n</div>\\n\\n{/* CTA Section */}\\n<div style={{ maxWidth: '1100px', margin: '0 auto', padding: '0 24px 100px', textAlign: 'center' }}>\\n  <h2 style={{ fontSize: '32px', fontWeight: 700, color: '#f9fafb', margin: '0 0 16px' }}>\\n    Ready to Trade?\\n  </h2>\\n  <p style={{ fontSize: '18px', color: '#9ca3af', margin: '0 0 32px' }}>\\n    Join Interstate and experience the future of trading today.\\n  </p>\\n  <a href=\\\"#\\\" style={{ display: 'inline-flex', alignItems: 'center', padding: '16px 40px', borderRadius: '12px', background: 'linear-gradient(135deg, #6366f1, #4f46e5)', color: '#fff', fontSize: '18px', fontWeight: 600, textDecoration: 'none' }}>\\n    Get Started\\n  </a>\\n</div>\\n\\n</div>\\n\",\"document\":[]}}"
